deploymentMode: SingleBinary

singleBinary:
  replicas: {{ loki_replicas }}

loki:
  auth_enabled: false
  commonConfig:
    replication_factor: 1
  limits_config:
    allow_structured_metadata: true
    volume_enabled: true
  pattern_ingester:
    enabled: true
  schemaConfig:
    configs:
      - from: "2024-04-01"
        schema: v13
        store: tsdb
        object_store: filesystem
        index:
          period: 24h
          prefix: loki_index_
  storage:
    type: filesystem

gateway:
  resources:
    requests:
      cpu: 10m
      memory: 32Mi
    limits:
      cpu: 100m
      memory: 64Mi

chunksCache:
  enabled: true
  allocatedMemory: {{ loki_chunks_cache_memory }}
  resources:
    limits:
      cpu: 500m
      memory: 2Gi
    requests:
      cpu: 100m
      memory: 2Gi
