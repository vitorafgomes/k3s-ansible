---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: circuit-breaker-backend
  namespace: "{{ traefik_namespace }}"
spec:
  circuitBreaker:
    expression: "NetworkErrorRatio() > 0.30 || ResponseCodeRatio(500, 600, 0, 600) > 0.25"
    checkPeriod: 10s
    fallbackDuration: 30s
    recoveryDuration: 60s
{% if traefik_admin_allowed_ips | default([]) | length > 0 %}
---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: ip-whitelist-admin
  namespace: "{{ traefik_namespace }}"
spec:
  ipAllowList:
    sourceRange:
{% for ip in traefik_admin_allowed_ips %}
      - "{{ ip }}"
{% endfor %}
    ipStrategy:
      depth: 1
{% endif %}
---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: rate-limit-api
  namespace: "{{ traefik_namespace }}"
spec:
  rateLimit:
    average: 100
    burst: 50
    period: 1s
---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: retry-policy
  namespace: "{{ traefik_namespace }}"
spec:
  retry:
    attempts: 3
    initialInterval: 100ms
{% if traefik_cors_allowed_origins | default([]) | length > 0 %}
---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: cors-otel
  namespace: "{{ traefik_namespace }}"
spec:
  headers:
    accessControlAllowMethods:
      - GET
      - POST
      - PUT
      - DELETE
      - OPTIONS
    accessControlAllowHeaders:
      - "*"
    accessControlAllowOriginList:
{% for origin in traefik_cors_allowed_origins %}
      - "{{ origin }}"
{% endfor %}
    accessControlAllowCredentials: true
    accessControlMaxAge: 3600
    addVaryHeader: true
{% if traefik_deploy_monitoring_middleware | default(true) %}
---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: cors-otel
  namespace: monitoring
spec:
  headers:
    accessControlAllowMethods:
      - GET
      - POST
      - PUT
      - DELETE
      - OPTIONS
    accessControlAllowHeaders:
      - "*"
    accessControlAllowOriginList:
{% for origin in traefik_cors_allowed_origins %}
      - "{{ origin }}"
{% endfor %}
    accessControlAllowCredentials: true
    accessControlMaxAge: 3600
    addVaryHeader: true
{% endif %}
{% endif %}
{% if traefik_deploy_keycloak_middleware | default(true) %}
---
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: strip-keycloak-prefix
  namespace: smart-management
spec:
  stripPrefix:
    prefixes:
      - /keycloak-orchestrator
{% endif %}
