---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: selfsigned-issuer
spec:
  selfSigned: {}
---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-staging
spec:
  acme:
    email: "{{ acme_email }}"
    server: https://acme-staging-v02.api.letsencrypt.org/directory
    privateKeySecretRef:
      name: letsencrypt-staging-account-key
{% if cloudflare_api_token | default('') | length > 0 %}
    solvers:
{% if cloudflare_dns_zones | default([]) | length > 0 %}
      - selector:
          dnsZones:
{% for zone in cloudflare_dns_zones %}
            - "{{ zone }}"
{% endfor %}
        dns01:
          cloudflare:
            apiTokenSecretRef:
              name: cloudflare-api-token-secret
              key: api-token
{% else %}
      - dns01:
          cloudflare:
            apiTokenSecretRef:
              name: cloudflare-api-token-secret
              key: api-token
{% endif %}
{% else %}
    solvers:
      - http01:
          ingress:
            class: traefik
{% endif %}
---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-prod
spec:
  acme:
    email: "{{ acme_email }}"
    server: https://acme-v02.api.letsencrypt.org/directory
    privateKeySecretRef:
      name: letsencrypt-prod-account-key
{% if cloudflare_api_token | default('') | length > 0 %}
    solvers:
{% if cloudflare_dns_zones | default([]) | length > 0 %}
      - selector:
          dnsZones:
{% for zone in cloudflare_dns_zones %}
            - "{{ zone }}"
{% endfor %}
        dns01:
          cloudflare:
            apiTokenSecretRef:
              name: cloudflare-api-token-secret
              key: api-token
{% else %}
      - dns01:
          cloudflare:
            apiTokenSecretRef:
              name: cloudflare-api-token-secret
              key: api-token
{% endif %}
{% else %}
    solvers:
      - http01:
          ingress:
            class: traefik
{% endif %}
